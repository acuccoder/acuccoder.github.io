    <script src="/assets/js/script.js" type="module"></script> <!-- ! Cannot use import statement outside a module ! --> <!-- <-- That haunts my dreams. -->
    <script src="/node_modules/typed.js/dist/typed.umd.js"></script>
    <script>
        var typed = new Typed('#intro', {
            strings: ['Hi! My name is Aaravv', 'I am 10 years old'],
            typeSpeed: 30,
            loop: true,
            loopCount: Infinity,
            cursorChar: '|'
        });
    </script>
